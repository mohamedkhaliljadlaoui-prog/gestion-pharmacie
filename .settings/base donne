-- Création de la base de données
CREATE DATABASE IF NOT EXISTS pharmacie_db;
USE pharmacie_db;

-- 1. Table client
CREATE TABLE IF NOT EXISTS client (
    id_client INT NOT NULL AUTO_INCREMENT,
    nom VARCHAR(50) NOT NULL,
    prenom VARCHAR(50) NOT NULL,
    email VARCHAR(100),
    adresse VARCHAR(255),
    telephone VARCHAR(20),
    PRIMARY KEY (id_client)
);

-- 2. Table pharmacien
CREATE TABLE IF NOT EXISTS pharmacien (
    id_pharmacien INT NOT NULL AUTO_INCREMENT,
    nom VARCHAR(50) NOT NULL,
    prenom VARCHAR(50) NOT NULL,
    login VARCHAR(50) NOT NULL UNIQUE,
    pwd VARCHAR(255) NOT NULL,
    PRIMARY KEY (id_pharmacien)
);

-- 3. Table gestionnaire
CREATE TABLE IF NOT EXISTS gestionnaire (
    id_gestionnaire INT NOT NULL AUTO_INCREMENT,
    nom VARCHAR(50) NOT NULL,
    prenom VARCHAR(50) NOT NULL,
    login VARCHAR(50) NOT NULL UNIQUE,
    pwd VARCHAR(255) NOT NULL,
    PRIMARY KEY (id_gestionnaire)
);

-- 4. Table medicament
CREATE TABLE IF NOT EXISTS medicament (
    id_medicament INT NOT NULL AUTO_INCREMENT,
    nom VARCHAR(100) NOT NULL,
    dosage VARCHAR(50),
    stock INT DEFAULT 0,
    prix_unitaire DECIMAL(10,2) NOT NULL,
    seuil_alerte INT DEFAULT 10,
    description TEXT,
    PRIMARY KEY (id_medicament)
);

-- 5. Table commande
CREATE TABLE IF NOT EXISTS commande (
    id_commande INT NOT NULL AUTO_INCREMENT,
    id_gestionnaire INT,
    id_medicament INT,
    quantite INT NOT NULL,
    date_commande TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statut VARCHAR(20) DEFAULT 'en_attente',
    date_reception TIMESTAMP NULL,
    PRIMARY KEY (id_commande),
    FOREIGN KEY (id_gestionnaire) REFERENCES gestionnaire(id_gestionnaire) ON DELETE SET NULL,
    FOREIGN KEY (id_medicament) REFERENCES medicament(id_medicament) ON DELETE SET NULL
);

-- 6. Table vente
CREATE TABLE IF NOT EXISTS vente (
    id_vente INT NOT NULL AUTO_INCREMENT,
    id_pharmacien INT,
    id_client INT,
    id_medicament INT,
    quantite INT NOT NULL,
    prix_total DECIMAL(10,2) NOT NULL,
    date_vente TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    statut VARCHAR(20) DEFAULT 'valide',
    PRIMARY KEY (id_vente),
    FOREIGN KEY (id_pharmacien) REFERENCES pharmacien(id_pharmacien) ON DELETE SET NULL,
    FOREIGN KEY (id_client) REFERENCES client(id_client) ON DELETE SET NULL,
    FOREIGN KEY (id_medicament) REFERENCES medicament(id_medicament) ON DELETE SET NULL
);

-- 7. Table stock_historique
CREATE TABLE IF NOT EXISTS stock_historique (
    id_historique INT NOT NULL AUTO_INCREMENT,
    id_medicament INT,
    quantite_avant INT NOT NULL,
    quantite_apres INT NOT NULL,
    type_operation VARCHAR(20) NOT NULL,
    id_operation INT,
    date_operation TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id_historique),
    FOREIGN KEY (id_medicament) REFERENCES medicament(id_medicament) ON DELETE SET NULL
);

